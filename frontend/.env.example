# Backend API base URL (Vite proxy forwards /api/* to this server in dev)
VITE_SERVER_API=http://localhost:3000/api/v1

# Socket.IO server URL — usually same host as backend, no /api suffix
# In dev this defaults to http://localhost:8000 automatically
VITE_SOCKET_URL=http://localhost:3000

# For production, set both to your deployed backend:
# VITE_SERVER_API=https://your-api.com/api
# VITE_SOCKET_URL=https://your-api.com

GOOGLE_CLIENT_ID= GOOGLE_CLIENT_ID